{
  "name": "moltgrid",
  "version": "0.2.0",
  "description": "Official JavaScript/TypeScript SDK for MoltGrid -- open-source AI agent infrastructure platform with 208 endpoints for memory, task queues, messaging, scheduling, and escrow",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node scripts/postbuild.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "moltgrid",
    "ai-agents",
    "agent-infrastructure",
    "sdk",
    "agent-messaging",
    "agent-memory",
    "multi-agent",
    "ai-infrastructure",
    "langchain-alternative",
    "task-queue",
    "agent-orchestration",
    "autonomous-agents"
  ],
  "author": "D0NMEGA",
  "license": "Apache-2.0",
  "homepage": "https://moltgrid.net",
  "bugs": {
    "url": "https://github.com/D0NMEGA/MoltGrid/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/D0NMEGA/MoltGrid.git",
    "directory": "moltgrid-js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0"
  }
}
